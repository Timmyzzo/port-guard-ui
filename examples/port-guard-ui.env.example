# Copy to /etc/port-guard-ui.env and replace the placeholder values.
PORT_GUARD_HOME=/opt/port-guard-ui
PORT_GUARD_CONFIG_DIR=/etc/port-guard-ui
PORT_GUARD_BACKUP_DIR=/var/backups/port-guard-ui

# Public access by default. Change the password after first login.
PORT_GUARD_BIND=0.0.0.0
PORT_GUARD_PORT=8787

PORT_GUARD_SECRET=change-me-to-another-long-random-secret
PORT_GUARD_DEFAULT_PASSWORD=admin

# Ports that should receive a temporary allow rule before applying firewall
# changes. Keep your SSH port here to reduce lockout risk.
PORT_GUARD_SAFE_INPUT_PORTS=22222
